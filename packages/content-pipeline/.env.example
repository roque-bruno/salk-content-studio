# Content Pipeline — Variáveis de Ambiente
# Copie para .env e preencha com suas credenciais

# === OBRIGATÓRIO ===
# API Key do Google AI Studio (aistudio.google.com/apikey)
GOOGLE_API_KEY=your-api-key-here

# === OPCIONAIS — Gemini ===
# GEMINI_MODEL=gemini-2.0-flash-exp
# GEMINI_IMAGE_MODEL=gemini-2.0-flash-exp
# GEMINI_TEMPERATURE=0.4
# GEMINI_TIMEOUT=120
# GEMINI_MAX_RETRIES=3

# === OPCIONAIS — NB2 ===
# NB2_WIDTH=1080
# NB2_HEIGHT=1350
# NB2_MAX_ATTEMPTS=3
# NB2_SAVE_INTERMEDIATE=true

# === OPCIONAIS — Pipeline ===
# BATCH_SIZE=5
# PARALLEL_WORKERS=2
# LOG_LEVEL=INFO

# === OPCIONAIS — Diretórios ===
# ASSETS_DIR=../../docs_user
# OUTPUT_DIR=../../output
# VDP_DIR=../../squads/content-production/output
